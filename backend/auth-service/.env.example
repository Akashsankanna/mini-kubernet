# Backend Environment Variables

# Database Configuration
DATABASE_URL=postgres://postgres:akash45@localhost:5432/mini_kubernet?sslmode=disable

# JWT Configuration
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-change-in-production
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Service Port
PORT=8081
GIN_MODE=release

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Rate Limiting
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_OTP_ATTEMPTS=3
RATE_LIMIT_REG_ATTEMPTS=10
RATE_LIMIT_WINDOW_SECONDS=900

# OTP Configuration
MAX_OTP_ATTEMPTS=3
OTP_EXPIRY_MINUTES=5

# Email Configuration (for OTP/notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@kubernet.io

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/kubernet/auth-service.log
