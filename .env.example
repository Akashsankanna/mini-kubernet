# Environment Variables Configuration

# Database
DATABASE_URL=postgresql://admin:password@postgres:5432/kubernet
DB_HOST=postgres
DB_PORT=5432
DB_NAME=kubernet
DB_USER=admin
DB_PASSWORD=secure-password-change-me

# Redis
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRY=86400

# Service Configuration
AUTH_SERVICE_URL=http://auth-service:8081
BUILD_SERVICE_URL=http://build-service:8082
DEPLOY_SERVICE_URL=http://deploy-service:8083
API_GATEWAY_URL=http://api-gateway:8080

# Docker Registry
DOCKER_REGISTRY=gcr.io/my-project
DOCKER_TAG=latest

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# GCP Configuration
GCP_PROJECT=your-project-id
GCP_ZONE=us-central1-a

# Kubernetes Configuration
KUBECONFIG=~/.kube/config
K8S_NAMESPACE=kubernet-prod
K8S_CONTEXT=default

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Monitoring
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000

# Feature Flags
ENABLE_ISTIO=true
ENABLE_CANARY=true
ENABLE_MULTI_CLUSTER=true
ENABLE_MONITORING=true
